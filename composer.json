{
    "name": "webictbyleo/odoid",
    "description": "Deterministic mixed-radix ID encoding — maps integers to 6, 7, or 8-character alphanumeric strings. Ambiguous characters I, L, O excluded.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Webictbyleo",
            "homepage": "https://github.com/Webictbyleo"
        }
    ],
    "keywords": ["id", "encoding", "serial", "deterministic"],
    "homepage": "https://github.com/Webictbyleo/odoid",
    "support": {
        "source": "https://github.com/Webictbyleo/odoid",
        "issues": "https://github.com/Webictbyleo/odoid/issues"
    },
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Webictbyleo\\OdoID\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webictbyleo\\OdoID\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
